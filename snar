#!/bin/bash

# COLORES
amarillo='\e[33m'
rojo='\e[31m'
verde='\e[32m'
reset='\e[39m'
negrita='\e[1m'

# Escaneo inicial
echo -ne "${negrita}"
echo -e """
             ${rojo}     ‚ĖĄ‚ĖĄ        
${verde}  ‚ĖĄ‚ĖĄ‚ĖĄ   ‚ĖĄ ‚ĖĄ‚ĖĄ  ${rojo}   ‚ĖĄ‚ĖÄ‚Ėą  ${verde} ‚ĖĄ ‚ĖĄ‚ĖĄ 
${verde} ‚Ėą   ‚ĖÄ  ‚Ėą‚ĖÄ  ‚Ėą ${rojo}  ‚Ėą‚ĖÄ ‚Ėą  ${verde} ‚Ėą‚ĖÄ  ‚ĖÄ
${verde}  ‚ĖÄ‚ĖÄ‚ĖÄ‚ĖĄ  ‚Ėą   ‚Ėą ${rojo} ‚Ėą‚ĖĄ‚ĖĄ‚ĖĄ‚Ėą‚ĖĄ ${verde} ‚Ėą    
${verde} ‚ĖÄ‚ĖĄ‚ĖĄ‚ĖĄ‚ĖÄ  ‚Ėą   ‚Ėą ${rojo}     ‚Ėą  ${verde} ‚Ėą    
                                              
"""
echo -ne "${reset}"

echo "Por: b4zh"
echo "Versi√≥n: 0.1"
echo -e "${amarillo}"
echo "[+] Escaneo inicial a $1"
echo
nmap -Pn -n -p- --open --min-rate 5000 --reason -oN init.nmap $1 1>/dev/null 2>errors.txt

# Obteniendo puertos abiertos
ports=$(grep "^[0-9]" init.nmap | cut -d "/" -f1 | xargs | tr " " "," | tee ports.txt 2>>errors.txt)
echo -e "[+] Puertos abiertos: ${reset}$ports${amarillo}"
echo

# Escaneando los servicios de los puertos abiertos, y enviando los scripts de default de nmap
echo "[+] Escaneando servicios..."
echo
nmap -Pn -n -p${ports} --open -sVC --min-rate 5000 --reason -oN services.nmap $1 1>/dev/null 2>>errors.txt

#echo $? PENDIENTE PERRO CALIENTE
echo -e "${reset}[+] FIN"
